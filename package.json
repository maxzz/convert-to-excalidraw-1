{
    "name": "markdown-mermaid-to-excalidraw",
    "version": "1.0.0",
    "description": "CLI utility to extract Mermaid diagrams from Markdown and convert them to Excalidraw files",
    "author": "Max Zakharzhevskiy",
    "license": "MIT",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "me2ex-conv": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "mermaid",
        "excalidraw",
        "markdown",
        "cli",
        "converter"
    ],
    "devDependencies": {
        "@types/node": "^25.7.0",
        "tsdown": "^0.22.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@excalidraw/excalidraw": "^0.18.1",
        "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
        "commander": "^14.0.3",
        "picocolors": "^1.1.1",
        "puppeteer": "^24.43.1"
    },
    "scripts": {
        "build": "node scripts/build.js && tsc",
        "debug": "tsx --inspect-brk src/index.ts",
        "start": "node dist/index.js",
        "prepublishOnly": "pnpm run build",
        "to-npm": "pnpm run build && pnpm publish"
    }
}
