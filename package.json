{
    "name": "markdown-mermaid-to-excalidraw",
    "version": "1.0.0",
    "description": "CLI utility to extract Mermaid diagrams from Markdown and convert them to Excalidraw files",
    "author": "Max Zakharzhevskiy",
    "license": "MIT",
    "main": "dist/index.js",
    "bin": {
        "mermaid-to-excalidraw": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "mermaid",
        "excalidraw",
        "markdown",
        "cli",
        "converter"
    ],
    "devDependencies": {
        "@types/node": "^20.0.0",
        "esbuild": "^0.20.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@excalidraw/excalidraw": "^0.17.6",
        "@excalidraw/mermaid-to-excalidraw": "^1.0.0",
        "commander": "^12.0.0",
        "puppeteer": "^22.0.0"
    },
    "scripts": {
        "build": "node build.js && tsc",
        "start": "node dist/index.js",
        "prepublishOnly": "pnpm run build"
    }
}
